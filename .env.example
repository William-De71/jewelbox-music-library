# Environment variables for JewelBox Music Library

# Discogs API Credentials (optional)
# Get your Consumer Key/Secret from: https://www.discogs.com/settings/developers
# Leave empty to use Discogs without authentication (lower rate limits)
# DISCOGS_KEY=your_discogs_consumer_key_here
# DISCOGS_SECRET=your_discogs_consumer_secret_here

# Database path (optional, defaults to server/data/jewelbox.db)
# DB_PATH=./data/jewelbox.db
